DATABASE_URL="postgresql://user:password@host:5432/docsync?sslmode=require"
AUTH_SECRET="replace-with-auth-secret"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"
GROQ_API_KEY=""

# Email invites (Nodemailer / SMTP) — optional; copy-link still works without these
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="DocSync <your-email@gmail.com>"
